From: Oh My Pi Discord Bridge <discord@example.com>
Date: Sun Feb 23 17:30:00 2025
Subject: [PATCH] Add correlation ID to RPC events for multi-client support

Add optional `id` field to all RPC event types to enable correlation
between commands and their associated streaming events. This enables
multiple clients to simultaneously use the RPC interface and correctly
route responses to the appropriate client.

Use case:
- Discord bot with multiple users prompting simultaneously
- Multiple agent instances using the same OMP process
- Web applications with concurrent users

The `id` field is optional to maintain backward compatibility.
---
 src/extensibility/extensions/types.ts | 11 +++++++++--
 1 file changed, 9 insertions(+), 2 deletions(-)

diff --git a/src/extensibility/extensions/types.ts b/src/extensibility/extensions/types.ts
index abc1234..def5678 100644
--- a/src/extensibility/extensions/types.ts
+++ b/src/extensibility/extensions/types.ts
@@ -1,6 +1,7 @@
 /** Fired when an agent loop starts */
 export interface AgentStartEvent {
 	type: "agent_start";
+	id?: string;
 }
 
 /** Fired when an agent loop ends */
 export interface AgentEndEvent {
 	type: "agent_end";
 	messages: AgentMessage[];
+	id?: string;
 }
 
 /** Fired at the start of each turn */
 export interface TurnStartEvent {
 	type: "turn_start";
 	turnIndex: number;
 	timestamp: number;
+	id?: string;
 }
 
 /** Fired at the end of each turn */
 export interface TurnEndEvent {
 	type: "turn_end";
 	turnIndex: number;
 	message: AgentMessage;
 	toolResults: ToolResultMessage[];
+	id?: string;
 }
 
 /** Fired when a message starts (user, assistant, or toolResult) */
@@ -120,6 +121,7 @@ export interface MessageUpdateEvent {
 	type: "message_update";
 	message: AgentMessage;
 	assistantMessageEvent: AssistantMessageEvent;
+	id?: string;
 }
 
 /** Fired when a message ends */
@@ -128,6 +130,7 @@ export interface MessageEndEvent {
 export interface ToolExecutionStartEvent {
 	type: "tool_execution_start";
 	toolCallId: string;
 	toolName: string;
 	args: unknown;
 	intent?: string;
+	id?: string;
 }
 
 /** Fired during tool execution with partial/streaming output */
@@ -136,6 +139,7 @@ export interface ToolExecutionUpdateEvent {
 	type: "tool_execution_update";
 	toolCallId: string;
 	toolName: string;
 	args: unknown;
 	partialResult: unknown;
+	id?: string;
 }
 
 /** Fired when a tool finishes executing */
@@ -144,4 +148,5 @@ export interface ToolExecutionEndEvent {
 	type: "tool_execution_end";
 	toolCallId: string;
 	toolName: string;
 	result: unknown;
 	isError: boolean;
+	id?: string;
 }
--
