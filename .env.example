# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: command prefix (default: !)
# DISCORD_PREFIX=!

# Optional: path to omp binary (default: omp, resolved via PATH)
# OMP_PATH=/home/user/.bun/bin/omp

# Optional: working directory for OMP subprocesses (default: $HOME)
# This is also the sandbox root — !omp cd, !omp ls, and !omp .. cannot
# navigate above this path.
# OMP_WORK_DIR=/home/user/projects
